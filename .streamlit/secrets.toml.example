# Copy to secrets.toml (never commit real keys)
# Free LLM is preferred when AI_PROVIDER is unset: Ollama (if running) → Gemini → Groq → Together → OpenAI.
# Enable "Use free/local LLM when available" in the sidebar.

# --- Streamlit Community Cloud / shared host (required for tester URL) ---
# Paste into App settings → Secrets on share.streamlit.io
ESA_HOSTED_MODE = "1"
# Optional hardening on public cloud:
# ESA_JSON_LOG = "1"
# ESA_AUDIT_ENABLED = "1"

# --- Recommended: local Ollama (free, private — site files stay on your PC) ---
# Install: https://ollama.com then: ollama pull qwen2.5:7b
# If Ollama is running, the app auto-detects it (no secrets required).
# AI_PROVIDER = "ollama"
# OPENAI_API_KEY = "ollama"
# OPENAI_BASE_URL = "http://localhost:11434/v1"
# OPENAI_MODEL = "qwen2.5:7b"

# --- Google Gemini (free tier — AI Studio) ---
# Get key: https://aistudio.google.com/apikey
# AI_PROVIDER = "gemini"
# GEMINI_API_KEY = "..."
# OPENAI_MODEL = "gemini-2.0-flash"

# --- Groq (free tier / fast cloud) ---
# AI_PROVIDER = "groq"
# GROQ_API_KEY = "gsk_..."
# OPENAI_MODEL = "llama-3.1-8b-instant"

# --- Together AI (free credits / low cost) ---
# AI_PROVIDER = "together"
# TOGETHER_API_KEY = "..."
# OPENAI_MODEL = "meta-llama/Llama-3.3-70B-Instruct-Turbo"

# --- Cloud OpenAI (paid) ---
# AI_PROVIDER = "openai"
# OPENAI_API_KEY = "sk-..."
# OPENAI_MODEL = "gpt-4o-mini"

# --- Azure OpenAI (optional) ---
# AI_PROVIDER = "azure"
# OPENAI_API_KEY = "..."
# AZURE_OPENAI_ENDPOINT = "https://YOUR-RESOURCE.openai.azure.com/openai/v1"
# OPENAI_MODEL = "gpt-4o-mini"

# --- Force offline heuristics ---
# AI_PROVIDER = "offline"
