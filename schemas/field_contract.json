{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ESA Report Generator field contract",
  "description": "Legacy reference for field names. Primary recommended-field lists live in schemas/report_profiles.json per profile; contract_warnings() reads profiles first.",
  "version": "1.2.0",
  "preparing_firm_default": "Ecoventure Inc.",
  "sheets": {
    "ProjectData": {
      "layout": "Row 1 = column headers (become Jinja keys after normalization). Row 2 = values for the report.",
      "recommended_all_phases": [
        "site_name",
        "client_name",
        "project_number",
        "address",
        "prepared_by",
        "date_of_issue"
      ],
      "recommended_phase_1_alberta_og": [
        "consultant_name",
        "company",
        "well_name",
        "uwi",
        "well_depth_m",
        "report_title",
        "qp_names",
        "spud_date",
        "cased_date",
        "reentry_detail",
        "drilling_waste_summary",
        "aer_waste_compliance_option",
        "cuttings_volume_on_lease_m3",
        "directive_050_notification_ref",
        "dwda_salinity_pathway",
        "air_photo_observations",
        "site_visit_completed",
        "site_visit_date",
        "executive_summary",
        "conclusions_recommendations",
        "asset_activity_type",
        "prior_reclamation_cert_number",
        "records_review_summary",
        "interview_operator_summary",
        "interview_landowner_summary",
        "flare_pit_used",
        "no_drilling_waste_on_site",
        "site_visit_photo_notes"
      ],
      "recommended_dwda": [
        "dwda_phase2_required",
        "dwda_calc_summary",
        "dwda_metal_sacks_per_metre",
        "dwda_salt_sacks_per_m3",
        "phase2_drilling_waste_required",
        "phase2_recommended"
      ],
      "recommended_phase_2": [
        "site_address",
        "report_title",
        "lab_name",
        "consultant_name",
        "company"
      ]
    },
    "DrillingWaste": {
      "layout": "One row per disposal record. Loop variable: drilling_waste.",
      "required_phase_1_alberta": false,
      "loop_variable": "drilling_waste",
      "row_fields": [
        "disposal_type",
        "gps_coordinates",
        "sump_depth_m",
        "cover_depth_m",
        "disposal_method",
        "volume_m3",
        "location",
        "waste_manifest_refs"
      ]
    },
    "StorageTanks": {
      "layout": "One row per tank. Loop variable: storage_tanks.",
      "required_phase_1_alberta": false,
      "loop_variable": "storage_tanks",
      "row_fields": ["tank_type", "content", "location", "capacity_m3"]
    },
    "Apecs": {
      "layout": "One row per area of potential environmental concern. Loop variable: apecs.",
      "required_phase_1_alberta": false,
      "loop_variable": "apecs",
      "row_fields": [
        "apec_id",
        "apec_name",
        "location_description",
        "concern_type",
        "source_of_concern",
        "evidence_summary",
        "source_document",
        "phase2_recommended",
        "notes"
      ]
    },
    "LabResults": {
      "layout": "One row per analyte. Headers: Analyte, Result, Unit, Criteria, Exceedance (aliases accepted).",
      "required_phase_2": true,
      "loop_variable": "lab_results",
      "row_fields": ["analyte", "result", "unit", "criteria", "exceedance_flag", "result_display"]
    },
    "DwdaChecklist": {
      "layout": "One row per checklist item. Loop variable: dwda_checklist.",
      "loop_variable": "dwda_checklist",
      "row_fields": ["checklist_item_id", "response", "notes"]
    },
    "DwdaCalculations": {
      "layout": "Optional calc ingest row(s). Context key dwda_calc_sheet is flattened into scalar calc fields and popped — not a Word table loop.",
      "ingest_key": "dwda_calc_sheet",
      "row_fields": [
        "metal_sacks_per_metre",
        "salt_sacks_per_m3",
        "salt_naoh_equiv_total",
        "salt_waste_volume_m3",
        "dst_resistivity_sacks_total",
        "dst_chloride_sacks_total"
      ]
    }
  },
  "sidebar_meta": {
    "prepared_by": "Author name (Ecoventure QP)",
    "date_of_issue": "ISO date",
    "report_phase": "Phase 1 | Phase 2",
    "template_version": "Optional semantic version of the Word template (e.g. 2.1.0)"
  },
  "template_rules": [
    "Type each {{ tag }} in one continuous run in Word (no bold/color mid-tag).",
    "Use static table header row, then {%tr for item in lab_results %} for Phase 2 lab data.",
    "Phase 1 Alberta: {%tr for item in drilling_waste %} and storage_tanks loops.",
    "Reports originate from Ecoventure Inc.; client data per project Excel.",
    "Run pre-flight before every production generate."
  ]
}
