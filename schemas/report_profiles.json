{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ESA Report Generator — report type profiles",
  "version": "1.1.0",
  "config_sheet": "ReportConfig",
  "primary_sheet_default": "ProjectData",
  "profiles": {
    "phase1_alberta": {
      "label": "Alberta Phase I ESA (Ecoventure)",
      "description": "AER SED 002 Phase 1 ESA (Section 10); drilling waste and tank tables.",
      "default_phase": "Phase 1",
      "primary_sheet": "ProjectData",
      "required_sheets": ["ProjectData"],
      "sheet_mappings": {
        "LabResults": "lab_results",
        "DrillingWaste": "drilling_waste",
        "StorageTanks": "storage_tanks"
      },
      "lab_loop_variable": null,
      "narrative_profile": "phase1_alberta",
      "recommended_fields": [
        "site_name",
        "client_name",
        "project_number",
        "address",
        "prepared_by",
        "date_of_issue",
        "consultant_name",
        "company",
        "well_name",
        "uwi",
        "report_title",
        "qp_names",
        "spud_date",
        "cased_date",
        "reentry_detail",
        "drilling_waste_summary",
        "aer_waste_compliance_option",
        "air_photo_observations",
        "site_visit_completed",
        "site_visit_date",
        "executive_summary",
        "conclusions_recommendations",
        "asset_activity_type",
        "prior_reclamation_cert_number",
        "records_review_summary",
        "interview_operator_summary",
        "interview_landowner_summary",
        "flare_pit_used",
        "no_drilling_waste_on_site",
        "site_visit_photo_notes",
        "phase2_recommended"
      ]
    },
    "phase1_devon": {
      "label": "Devon 2017 reference Phase I (04-04-049-04W4M)",
      "description": "Full-layout template from Devon 2017 reference; uses SED 002 §10 Excel fields.",
      "default_phase": "Phase 1",
      "primary_sheet": "ProjectData",
      "required_sheets": ["ProjectData"],
      "sheet_mappings": {
        "DrillingWaste": "drilling_waste",
        "StorageTanks": "storage_tanks"
      },
      "lab_loop_variable": null,
      "narrative_profile": "phase1_alberta",
      "recommended_fields": [
        "site_name",
        "client_name",
        "well_name",
        "uwi",
        "consultant_name",
        "company",
        "executive_summary",
        "records_review_summary",
        "interview_operator_summary",
        "aer_waste_compliance_option",
        "drilling_waste_summary",
        "site_visit_completed",
        "phase2_esa_required",
        "qp_names",
        "prepared_by",
        "date_of_issue"
      ]
    },
    "phase2_esa": {
      "label": "Phase II ESA (laboratory results)",
      "description": "Requires LabResults sheet and lab_results table loop in Word.",
      "default_phase": "Phase 2",
      "primary_sheet": "ProjectData",
      "required_sheets": ["ProjectData", "LabResults"],
      "sheet_mappings": {
        "LabResults": "lab_results"
      },
      "lab_loop_variable": "lab_results",
      "narrative_profile": "phase2",
      "recommended_fields": [
        "site_name",
        "client_name",
        "project_number",
        "address",
        "prepared_by",
        "date_of_issue",
        "site_address",
        "report_title",
        "lab_name",
        "consultant_name",
        "company"
      ]
    },
    "groundwater_monitoring": {
      "label": "Groundwater monitoring (Ecoventure)",
      "description": "Monitoring wells, water levels, and GroundwaterLab results.",
      "default_phase": "Phase 1",
      "primary_sheet": "ProjectData",
      "required_sheets": ["ProjectData", "MonitoringWells", "WaterLevels", "GroundwaterLab"],
      "sheet_mappings": {
        "MonitoringWells": "monitoring_wells",
        "WaterLevels": "water_levels",
        "GroundwaterLab": "groundwater_results",
        "FieldNotes": "field_events"
      },
      "lab_loop_variable": "groundwater_results",
      "narrative_profile": "groundwater_monitoring",
      "recommended_fields": [
        "site_name",
        "client_name",
        "project_number",
        "address",
        "prepared_by",
        "date_of_issue",
        "consultant_name",
        "company",
        "report_title",
        "monitoring_program",
        "qp_names",
        "lab_name",
        "executive_summary",
        "hydrogeologic_setting",
        "conclusions_recommendations",
        "hydrograph_image_path",
        "site_map_image_path"
      ]
    },
    "reclamation_certificate": {
      "label": "Reclamation certificate (AER Schedule Two)",
      "description": "Phase I style fields plus reclamation task and soil placement tables.",
      "default_phase": "Phase 1",
      "primary_sheet": "ProjectData",
      "required_sheets": ["ProjectData"],
      "sheet_mappings": {
        "DrillingWaste": "drilling_waste",
        "StorageTanks": "storage_tanks",
        "ReclamationTasks": "reclamation_tasks",
        "SoilPlacement": "soil_placement",
        "Vegetation": "vegetation",
        "GroundwaterLab": "groundwater_results",
        "MonitoringWells": "monitoring_wells",
        "WaterLevels": "water_levels"
      },
      "lab_loop_variable": null,
      "narrative_profile": "phase1_alberta",
      "recommended_fields": [
        "site_name",
        "client_name",
        "project_number",
        "well_name",
        "uwi",
        "consultant_name",
        "company",
        "prepared_by",
        "date_of_issue",
        "executive_summary",
        "conclusions_recommendations",
        "certificate_status"
      ]
    },
    "phase3_remediation": {
      "label": "Phase III / remediation",
      "description": "Remediation objectives, treatment events, confirmatory sampling; shares GW lab sheets.",
      "default_phase": "Phase 2",
      "primary_sheet": "ProjectData",
      "required_sheets": ["ProjectData", "RemediationObjectives"],
      "sheet_mappings": {
        "RemediationObjectives": "remediation_objectives",
        "TreatmentEvents": "treatment_events",
        "ConfirmatorySampling": "confirmatory_sampling",
        "WasteManifests": "waste_manifests",
        "GroundwaterLab": "groundwater_results",
        "MonitoringWells": "monitoring_wells",
        "WaterLevels": "water_levels",
        "LabResults": "lab_results"
      },
      "lab_loop_variable": "groundwater_results",
      "narrative_profile": "groundwater_monitoring",
      "recommended_fields": [
        "site_name",
        "client_name",
        "project_number",
        "prepared_by",
        "date_of_issue",
        "consultant_name",
        "company",
        "report_title",
        "rap_status",
        "remediation_status",
        "executive_summary",
        "conclusions_recommendations"
      ]
    },
    "template_driven": {
      "label": "Custom — match template tags to Excel sheets",
      "description": "Maps Word {%tr for item in X %} loops and {{ fields }} to any Excel sheets you supply. Use ReportConfig sheet to override mappings.",
      "default_phase": "Phase 1",
      "primary_sheet": "ProjectData",
      "required_sheets": ["ProjectData"],
      "sheet_mappings": {},
      "auto_discover_loops": true,
      "auto_map_sheets": true,
      "lab_loop_variable": "lab_results",
      "narrative_profile": "generic",
      "recommended_fields": [
        "site_name",
        "client_name",
        "project_number",
        "address",
        "prepared_by",
        "date_of_issue"
      ]
    }
  }
}
